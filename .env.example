# =============================================================================
# ESXP Network Services - Environment configuration
# =============================================================================
# Copy this file to ".env" and adjust values. The installer also writes a
# populated copy to /etc/esxp-network-services/.env on the target machine.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Source repository
# -----------------------------------------------------------------------------
# The single place where the code repository URL lives. The installer and the
# update script clone/pull from THIS variable only -- never from a hard-coded
# URL. Replace the placeholder with your own Git remote when self-hosting.
REPO_URL=https://github.com/YOUR-ORG/YOUR-REPO.git
REPO_BRANCH=main

# -----------------------------------------------------------------------------
# Dashboard web app
# -----------------------------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Secret used to sign session cookies. The installer generates a random one.
# Change this to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# Session lifetime in seconds (default 8 hours).
SESSION_MAX_AGE=28800

# Path to the SQLite database (auth + audit log).
DB_PATH=/var/lib/esxp-network-services/dashboard.db

# Seed administrator account (created only if it does not already exist).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Kea Control Agent (REST API)
# -----------------------------------------------------------------------------
# The dashboard talks to Kea EXCLUSIVELY through this REST endpoint.
KEA_CA_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# systemd unit names (vary between distributions)
# -----------------------------------------------------------------------------
KEA_DHCP4_SERVICE=kea-dhcp4-server
KEA_DHCP6_SERVICE=kea-dhcp6-server
KEA_CTRL_AGENT_SERVICE=kea-ctrl-agent
