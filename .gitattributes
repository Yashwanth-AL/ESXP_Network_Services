# Ensure LF line endings for files that run on the Linux target,
# regardless of the OS the code is authored/cloned on.
* text=auto eol=lf

*.sh    text eol=lf
*.py    text eol=lf
*.conf  text eol=lf
*.service text eol=lf
*.json  text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
.env.example text eol=lf

# Binary assets
*.png   binary
*.jpg   binary
*.ico   binary
